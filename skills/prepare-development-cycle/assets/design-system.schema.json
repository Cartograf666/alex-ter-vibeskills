{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Cartograf666/alex-ter-vibeskills/main/schemas/design-system.schema.json",
  "title": "Project Design System Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "source", "visual_direction", "tokens", "components",
    "responsive", "accessibility", "quality_gate_ids", "approval"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "status": { "enum": ["provisional", "approved", "superseded"] },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "version", "official_url", "implementation_packages"],
      "properties": {
        "type": { "enum": ["existing", "adopted", "custom"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "official_url": { "type": ["string", "null"], "format": "uri" },
        "implementation_packages": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "visual_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traits", "density", "color_modes", "typography_strategy", "icon_strategy"],
      "properties": {
        "traits": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 2 }, "uniqueItems": true },
        "density": { "enum": ["compact", "comfortable", "spacious", "adaptive"] },
        "color_modes": { "type": "array", "minItems": 1, "items": { "enum": ["light", "dark", "high-contrast", "system"] }, "uniqueItems": true },
        "typography_strategy": { "type": "string", "minLength": 3 },
        "icon_strategy": { "type": "string", "minLength": 3 }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_paths", "categories"],
      "properties": {
        "source_paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/repositoryPath" }, "uniqueItems": true },
        "categories": {
          "type": "array", "minItems": 7, "uniqueItems": true,
          "items": { "enum": ["color", "typography", "spacing", "sizing", "radius", "border", "elevation", "motion", "breakpoint", "z-index"] }
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "registry_paths", "documentation_paths", "required_contracts"],
      "properties": {
        "source": { "enum": ["local", "library", "mixed"] },
        "registry_paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/repositoryPath" }, "uniqueItems": true },
        "documentation_paths": { "type": "array", "items": { "$ref": "#/$defs/repositoryPath" }, "uniqueItems": true },
        "required_contracts": {
          "type": "array", "uniqueItems": true,
          "allOf": [
            { "contains": { "const": "variants" } },
            { "contains": { "const": "states" } },
            { "contains": { "const": "accessibility" } }
          ],
          "items": { "enum": ["variants", "sizes", "states", "accessibility", "composition", "content"] }
        }
      }
    },
    "responsive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "required_viewports"],
      "properties": {
        "strategy": { "type": "string", "minLength": 3 },
        "required_viewports": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 2 }, "uniqueItems": true }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "requirements"],
      "properties": {
        "target": { "type": "string", "minLength": 3 },
        "requirements": {
          "type": "array", "uniqueItems": true,
          "allOf": [
            { "contains": { "const": "keyboard" } },
            { "contains": { "const": "focus-visible" } },
            { "contains": { "const": "semantics" } },
            { "contains": { "const": "contrast" } },
            { "contains": { "const": "reduced-motion" } }
          ],
          "items": { "type": "string", "minLength": 2 }
        }
      }
    },
    "quality_gate_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^GATE-[A-Z0-9][A-Z0-9_-]*$" }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "approved_by", "approved_at", "artifact_hashes", "manifest_sha256"],
      "properties": {
        "status": { "enum": ["pending", "approved", "invalidated"] },
        "approved_by": { "type": ["string", "null"] },
        "approved_at": { "type": ["string", "null"], "format": "date-time" },
        "artifact_hashes": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/repositoryPath" },
          "additionalProperties": { "$ref": "#/$defs/sha256" }
        },
        "manifest_sha256": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } } },
      "then": {
        "properties": {
          "approval": {
            "properties": {
              "status": { "const": "approved" },
              "approved_by": { "type": "string", "minLength": 1 },
              "approved_at": { "type": "string", "format": "date-time" },
              "artifact_hashes": { "minProperties": 1 },
              "manifest_sha256": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "source": { "properties": { "type": { "const": "adopted" } } } } },
      "then": { "properties": { "source": { "properties": { "official_url": { "type": "string", "format": "uri" } } } } }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "repositoryPath": { "type": "string", "minLength": 1, "not": { "pattern": "^(?:/|~|[A-Za-z]:[\\\\/])" } }
  }
}
